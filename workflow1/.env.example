# Gemini API keys — all three required for rotation
# Get free keys at: https://aistudio.google.com/app/apikey
# Free tier limits: 15 RPM, 1500 requests/day per key
# Three keys = 4500 requests/day total
GOOGLE_API_KEY_1=your_first_key_here
GOOGLE_API_KEY_2=your_second_key_here
GOOGLE_API_KEY_3=your_third_key_here

# Optional — LangSmith tracing (free tier at https://smith.langchain.com)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_PROJECT=workflow1-onboarding
