# Required — get free API key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Optional — LangSmith tracing (free tier available at smith.langchain.com)
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=tier8-loan-negotiation

# Optional request caps (rolling per-minute limits)
EMBEDDING_API_MAX_REQUESTS_PER_MIN=20
NEGOTIATION_API_MAX_REQUESTS_PER_MIN=12
NEGOTIATION_MAX_LLM_CALLS_PER_SESSION=4
